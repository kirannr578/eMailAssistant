# =====================================================================
# Email Assistant - environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# ---------- Mailbox to monitor ----------
# REQUIRED. The full email address of the inbox the agent should watch.
MAILBOX_ADDRESS=
# REQUIRED. IANA timezone name for parsing relative meeting times and
# creating calendar events. Examples:
#   America/New_York, America/Chicago, America/Denver, America/Los_Angeles
#   Europe/London, Europe/Berlin, Asia/Singapore, Asia/Kolkata, Australia/Sydney
# Run `python -c "from tzlocal import get_localzone; print(get_localzone())"`
# to see your machine's local timezone.
USER_TIMEZONE=
DEFAULT_MEETING_DURATION_MINUTES=30

# ---------- Your company (helps detect bid invitations addressed to you) ----------
# COMPANY_NAME is the legal/full name; COMPANY_ALIASES is a comma-separated
# list of nicknames / acronyms that senders might use.
# Example for "Blueprint Constructs":
#   COMPANY_NAME=Blueprint Constructs
#   COMPANY_ALIASES=BPC,Blueprint
COMPANY_NAME=
COMPANY_ALIASES=
# When the agent detects a bid request and a bid due date, automatically place
# a calendar reminder at that due time. Set to 0 to disable.
AUTO_BLOCK_BID_REMINDER=1

# ---------- Email + Calendar provider ----------
# Choose ONE of: outlook (Microsoft 365) | gmail (Google Workspace / personal Gmail)
EMAIL_PROVIDER=outlook

# ---------- Microsoft Graph (only if EMAIL_PROVIDER=outlook) ----------
# Create an app registration at https://entra.microsoft.com -> App registrations
#   - Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
#   - Allow public client flows: YES (Authentication -> Advanced settings)
#   - Delegated API permissions: Mail.ReadWrite, Calendars.ReadWrite, User.Read, offline_access
# OR run: .\scripts\setup_entra.ps1   (auto-creates the app)
MS_CLIENT_ID=
MS_TENANT_ID=common
MS_TOKEN_CACHE_PATH=token_cache.bin

# ---------- Google APIs (only if EMAIL_PROVIDER=gmail) ----------
# Setup walkthrough: README -> "Gmail / Google Workspace setup".
# Path to the OAuth Client JSON you downloaded from Google Cloud Console
# (APIs & Services -> Credentials -> Desktop client).
GOOGLE_CLIENT_SECRETS_PATH=client_secret.json
# Where Google's refresh token is cached. Keep OUT of git (already in .gitignore).
GOOGLE_TOKEN_CACHE_PATH=google_token.json
# Calendar to write events to. "primary" = the user's main calendar.
GOOGLE_CALENDAR_ID=primary

# ---------- LLM (analysis brain) ----------
# Choose ONE provider. All speak the OpenAI chat-completions API shape.
#   openai          -> api.openai.com         (paid, ~$0.0001/email)
#   azure_openai    -> your Azure OpenAI deployment (work account)
#   github_models   -> models.github.ai       (FREE with a GitHub PAT)
#   ollama          -> localhost:11434/v1     (FREE, runs locally on your laptop)
#   openai_compat   -> any OpenAI-compatible endpoint (LM Studio, vLLM, etc.)
LLM_PROVIDER=openai
LLM_API_KEY=
# Model name. For Azure, this is the DEPLOYMENT name (not the model name).
# Sensible defaults per provider:
#   openai        -> gpt-4o-mini
#   github_models -> gpt-4o-mini  (or openai/gpt-4o-mini depending on catalog)
#   ollama        -> llama3.1:8b  (or any model you've pulled with `ollama pull`)
LLM_MODEL=gpt-4o-mini
# Only needed for openai_compat or to override a default.
LLM_BASE_URL=
# Only needed for azure_openai:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---------- Notification channels ----------
# Comma-separated subset of: telegram, whatsapp_meta, whatsapp, sms
#   telegram       -> Telegram bot   (recommended; free, no limits, 5-min setup)
#   whatsapp_meta  -> Meta WhatsApp Cloud API direct (free up to 1000/mo, 30-min setup)
#   whatsapp       -> Twilio WhatsApp (sandbox is free, real number is paid)
#   sms            -> Twilio SMS     (real SMS, paid after $15 trial credit)
NOTIFY_CHANNELS=telegram

# ---------- Twilio (only if 'sms' or 'whatsapp' in NOTIFY_CHANNELS) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
NOTIFY_TO_SMS=
NOTIFY_TO_WHATSAPP=

# ---------- Meta WhatsApp Cloud API (only if 'whatsapp_meta' in NOTIFY_CHANNELS) ----------
# Setup walkthrough: README -> "Meta WhatsApp Cloud API setup".
# Phone Number ID is shown on Meta App dashboard -> WhatsApp -> API Setup.
META_WA_PHONE_NUMBER_ID=
# Long-lived System User token. Scopes: whatsapp_business_messaging, whatsapp_business_management
META_WA_ACCESS_TOKEN=
# Your WhatsApp number in E.164 WITHOUT the leading '+' (e.g. 15125551234).
META_WA_RECIPIENT=
# Optional: name of a pre-approved template used as fallback if the 24-hour
# session window has closed. Leave blank to skip the fallback.
META_WA_TEMPLATE_NAME=
META_WA_TEMPLATE_LANGUAGE=en_US
META_WA_API_VERSION=v21.0

# ---------- Telegram bot (only if 'telegram' in NOTIFY_CHANNELS) ----------
# Setup: in Telegram, message @BotFather, send /newbot, follow prompts.
# BotFather returns a token like "7891234567:AAH...xyz" -> paste below.
# Then search for your new bot in Telegram and tap Start so it has a chat.
# The setup wizard auto-discovers TELEGRAM_CHAT_ID for you.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Agent behavior ----------
POLL_INTERVAL_SECONDS=60
# Confidence threshold (0.0-1.0) above which a meeting is auto-blocked on calendar.
AUTO_BLOCK_CONFIDENCE=0.75
# Lookback window when first starting (minutes). Subsequent runs use the state DB.
INITIAL_LOOKBACK_MINUTES=60
# Where to store processed-message IDs.
STATE_DB_PATH=state.db
# Set to 1 for verbose logging
DEBUG=0
