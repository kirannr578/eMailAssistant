# =====================================================================
# Email Assistant - environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# ---------- Mailbox to monitor ----------
MAILBOX_ADDRESS=rocky@blueprintconstructs.com
USER_TIMEZONE=America/Chicago
DEFAULT_MEETING_DURATION_MINUTES=30

# ---------- Microsoft Graph (Outlook + Calendar) ----------
# Create an app registration at https://entra.microsoft.com -> App registrations
#   - Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
#   - Allow public client flows: YES (Authentication -> Advanced settings)
#   - Delegated API permissions: Mail.ReadWrite, Calendars.ReadWrite, User.Read, offline_access
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Use "common" for personal+work, your tenant GUID for single tenant, or "consumers" for personal only.
MS_TENANT_ID=common
# Where MSAL caches the refresh token. Keep this OUT of git (already in .gitignore).
MS_TOKEN_CACHE_PATH=token_cache.bin

# ---------- OpenAI (analysis LLM) ----------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ---------- Twilio (SMS + WhatsApp) ----------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Twilio phone number in E.164 format (the FROM for SMS)
TWILIO_FROM_SMS=+15555550123
# Twilio WhatsApp sender. For sandbox: whatsapp:+14155238886
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
# Your phone number to receive alerts (E.164)
NOTIFY_TO_SMS=+15555550000
NOTIFY_TO_WHATSAPP=whatsapp:+15555550000
# Which channels to actually send on: comma-separated subset of: sms,whatsapp
NOTIFY_CHANNELS=sms,whatsapp

# ---------- Agent behavior ----------
POLL_INTERVAL_SECONDS=60
# Confidence threshold (0.0-1.0) above which a meeting is auto-blocked on calendar.
AUTO_BLOCK_CONFIDENCE=0.75
# Lookback window when first starting (minutes). Subsequent runs use the state DB.
INITIAL_LOOKBACK_MINUTES=60
# Where to store processed-message IDs.
STATE_DB_PATH=state.db
# Set to 1 for verbose logging
DEBUG=0
